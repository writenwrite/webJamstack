---
interface Props {
  title: string;
  description: string;
  slug: string;
  image?: string;
  techStack?: string[];
}

const { title, description, slug, image, techStack = [] } = Astro.props;
---

<article class="card">
  {image && (
    <img
      src={image}
      alt={title}
      class="w-full h-48 object-cover rounded-lg mb-4"
    />
  )}

  <h3 class="text-xl font-bold mb-3">
    <a href={`/projects/${slug}`} class="hover:text-primary transition-colors">
      {title}
    </a>
  </h3>

  <p class="text-gray-400 mb-4">{description}</p>

  {techStack.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {techStack.map((tech) => (
        <span class="bg-gray-700 text-sm px-3 py-1 rounded-full text-gray-300">
          {tech}
        </span>
      ))}
    </div>
  )}

  <a href={`/projects/${slug}`} class="text-primary hover:text-blue-400 font-medium transition-colors">
    Lihat proyek &rarr;
  </a>
</article>
