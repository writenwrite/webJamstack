---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    title: 'E-Commerce Platform',
    description: 'Platform e-commerce full-stack dengan payment gateway dan admin dashboard.',
    slug: 'e-commerce-platform',
    techStack: ['Next.js', 'Sanity', 'Stripe', 'Tailwind'],
  },
  {
    title: 'Task Management App',
    description: 'Aplikasi manajemen tugas dengan fitur kolaborasi tim real-time.',
    slug: 'task-management',
    techStack: ['React', 'Node.js', 'MongoDB', 'Socket.io'],
  },
  {
    title: 'Blog Platform',
    description: 'Platform blog sederhana dengan CMS dan fitur markdown support.',
    slug: 'blog-platform',
    techStack: ['Astro', 'Sanity', 'Tailwind'],
  },
  {
    title: 'Weather Dashboard',
    description: 'Dashboard cuaca dengan visualisasi data dan prediksi 7 hari ke depan.',
    slug: 'weather-dashboard',
    techStack: ['Vue.js', 'OpenWeather API', 'Chart.js'],
  },
];
---

<BaseLayout title="Projects - Portfolio & Blog">
  <!-- Hero -->
  <section class="relative py-20 text-center">
    <div class="absolute top-10 left-1/4 w-64 h-64 bg-primary/10 rounded-full blur-[100px]"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="badge mb-6 inline-block">Proyek</span>
      <h1 class="text-5xl sm:text-6xl font-heading font-extrabold mb-6">
        <span class="gradient-text">Proyek Saya</span>
      </h1>
      <p class="section-subtitle">
        Kumpulan proyek yang telah saya kerjakan dan kembangkan.
      </p>
    </div>
  </section>

  <div class="divider my-8"></div>

  <!-- Projects Grid -->
  <section class="py-16 max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</BaseLayout>
