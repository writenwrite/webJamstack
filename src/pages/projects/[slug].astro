---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'e-commerce-platform' } },
    { params: { slug: 'task-management' } },
    { params: { slug: 'blog-platform' } },
    { params: { slug: 'weather-dashboard' } },
  ];
}

const { slug } = Astro.params;

const projects = {
  'e-commerce-platform': {
    title: 'E-Commerce Platform',
    description: 'Platform e-commerce full-stack dengan payment gateway dan admin dashboard.',
    techStack: ['Next.js', 'Sanity', 'Stripe', 'Tailwind CSS'],
    features: [
      'Product catalog dengan pencarian dan filter',
      'Shopping cart dan checkout flow',
      'Payment gateway dengan Stripe',
      'Admin dashboard untuk manajemen produk',
      'Responsive design untuk mobile',
    ],
    liveUrl: 'https://example.com',
    githubUrl: 'https://github.com',
  },
  'task-management': {
    title: 'Task Management App',
    description: 'Aplikasi manajemen tugas dengan fitur kolaborasi tim real-time.',
    techStack: ['React', 'Node.js', 'MongoDB', 'Socket.io'],
    features: [
      'Real-time collaboration dengan multiple users',
      'Drag and drop task management',
      'Due date dan priority settings',
      'Notification system',
      'Activity log dan audit trail',
    ],
    liveUrl: 'https://example.com',
    githubUrl: 'https://github.com',
  },
  'blog-platform': {
    title: 'Blog Platform',
    description: 'Platform blog sederhana dengan CMS dan fitur markdown support.',
    techStack: ['Astro', 'Sanity', 'Tailwind CSS'],
    features: [
      'Markdown support untuk konten',
      'Tags dan categories',
      'Search functionality',
      'RSS feed',
      'SEO optimized',
    ],
    liveUrl: 'https://example.com',
    githubUrl: 'https://github.com',
  },
  'weather-dashboard': {
    title: 'Weather Dashboard',
    description: 'Dashboard cuaca dengan visualisasi data dan prediksi 7 hari ke depan.',
    techStack: ['Vue.js', 'OpenWeather API', 'Chart.js'],
    features: [
      'Current weather dengan lokasi GPS',
      '7-day weather forecast',
      'Interactive charts',
      'Multiple location support',
      'Weather alerts',
    ],
    liveUrl: 'https://example.com',
    githubUrl: 'https://github.com',
  },
};

const project = projects[slug];

if (!project) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${project.title} - Projects`}>
  <!-- Hero -->
  <section class="relative py-20 text-center">
    <div class="absolute top-10 right-1/3 w-64 h-64 bg-secondary/10 rounded-full blur-[100px]"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="badge mb-6 inline-block">Proyek</span>
      <h1 class="text-4xl sm:text-5xl font-heading font-extrabold mb-4">
        {project.title}
      </h1>
      <p class="section-subtitle">{project.description}</p>
    </div>
  </section>

  <div class="divider my-8"></div>

  <!-- Content -->
  <section class="py-16 max-w-4xl mx-auto">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Features -->
        <div class="glass-card !p-8">
          <h2 class="font-heading font-bold text-xl mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Fitur Utama
          </h2>
          <ul class="space-y-4">
            {project.features.map((feature) => (
              <li class="flex items-start gap-3 text-gray-300">
                <span class="mt-1 w-5 h-5 rounded-full bg-secondary/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <!-- Links -->
        <div class="flex gap-4">
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-primary group">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            <span>Live Demo</span>
          </a>
          <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary group">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            <span>GitHub</span>
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Tech Stack -->
        <div class="glass-card !p-6">
          <h3 class="font-heading font-bold mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
            Tech Stack
          </h3>
          <div class="flex flex-wrap gap-2">
            {project.techStack.map((tech) => (
              <span class="badge">{tech}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Back Link -->
    <div class="mt-12">
      <a href="/projects" class="inline-flex items-center gap-2 text-primary-light hover:text-primary font-medium transition-colors group">
        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Kembali ke Projects
      </a>
    </div>
  </section>
</BaseLayout>
