---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featuredPosts = [
  {
    title: 'Memulai Belajar Web Development',
    excerpt: 'Panduan lengkap untuk pemula yang ingin belajar membuat website.',
    slug: 'memulai-belajar-web-development',
    date: '14 Juni 2026',
  },
  {
    title: 'Astro: Framework Modern untuk SSG',
    excerpt: 'Mengenal Astro dan mengapa framework ini cocok untuk portfolio.',
    slug: 'astro-framework-modern',
    date: '10 Juni 2026',
  },
];

const featuredProjects = [
  {
    title: 'E-Commerce Platform',
    description: 'Platform e-commerce full-stack dengan payment gateway.',
    slug: 'e-commerce-platform',
    techStack: ['Next.js', 'Sanity', 'Stripe'],
  },
  {
    title: 'Task Management App',
    description: 'Aplikasi manajemen tugas dengan fitur kolaborasi tim.',
    slug: 'task-management',
    techStack: ['React', 'Node.js', 'MongoDB'],
  },
];
---

<BaseLayout title="Home - Portfolio & Blog">
  <!-- Hero Section -->
  <section class="text-center py-20">
    <h1 class="text-5xl font-bold mb-6">
      Halo, Saya <span class="text-primary">Developer</span>
    </h1>
    <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
      Web developer yang passionate dalam membuat website modern dan performa tinggi.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/projects" class="btn-primary">Lihat Proyek</a>
      <a href="/about" class="bg-gray-700 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors">
        Tentang Saya
      </a>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="mb-16">
    <h2 class="text-3xl font-bold mb-8 text-center">Proyek Unggulan</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featuredProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/projects" class="text-primary hover:text-blue-400 font-medium transition-colors">
        Lihat semua proyek &rarr;
      </a>
    </div>
  </section>

  <!-- Latest Posts -->
  <section>
    <h2 class="text-3xl font-bold mb-8 text-center">Artikel Terbaru</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featuredPosts.map((post) => (
        <PostCard {...post} />
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/blog" class="text-primary hover:text-blue-400 font-medium transition-colors">
        Baca semua artikel &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
