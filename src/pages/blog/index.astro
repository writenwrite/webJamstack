---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = [
  {
    title: 'Memulai Belajar Web Development',
    excerpt: 'Panduan lengkap untuk pemula yang ingin belajar membuat website dari nol.',
    slug: 'memulai-belajar-web-development',
    date: '14 Juni 2026',
  },
  {
    title: 'Astro: Framework Modern untuk SSG',
    excerpt: 'Mengenal Astro dan mengapa framework ini cocok untuk portfolio dan blog.',
    slug: 'astro-framework-modern',
    date: '10 Juni 2026',
  },
  {
    title: 'Deploy Website Gratis ke Vercel',
    excerpt: 'Cara mudah deploy website Jamstack ke Vercel secara gratis.',
    slug: 'deploy-vercel',
    date: '5 Juni 2026',
  },
  {
    title: 'Setup Sanity CMS untuk Blog',
    excerpt: 'Panduan lengkap mengintegrasikan Sanity CMS dengan Astro.',
    slug: 'setup-sanity-cms',
    date: '1 Juni 2026',
  },
];
---

<BaseLayout title="Blog - Portfolio & Blog">
  <!-- Hero -->
  <section class="relative py-20 text-center">
    <div class="absolute top-10 right-1/4 w-64 h-64 bg-accent/10 rounded-full blur-[100px]"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <span class="badge mb-6 inline-block">Blog</span>
      <h1 class="text-5xl sm:text-6xl font-heading font-extrabold mb-6">
        <span class="gradient-text">Artikel</span>
      </h1>
      <p class="section-subtitle">
        Tulisan tentang web development, tips, dan tutorial yang saya bagikan.
      </p>
    </div>
  </section>

  <div class="divider my-8"></div>

  <!-- Posts Grid -->
  <section class="py-16 max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-6">
      {posts.map((post) => (
        <PostCard {...post} />
      ))}
    </div>
  </section>
</BaseLayout>
